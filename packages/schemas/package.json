{
	"name": "@clara/schemas",
	"version": "0.1.0",
	"private": true,
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"require": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"scripts": {
		"build": "tsc -p tsconfig.json && pnpm run generate-json-schemas",
		"generate-json-schemas": "node scripts/generate-json-schemas.js",
		"lint": "biome check",
		"format": "biome format \"src/**/*.{ts,tsx,js,json,md}\"",
		"test": "vitest",
		"test:ci": "vitest run --reporter verbose"
	},
	"dependencies": {
		"zod": "^3.23.0"
	},
	"devDependencies": {
		"@types/node": "^20.0.0",
		"uuid": "^9.0.0"
	}
}