# Development Dockerfile for Clara API
FROM node:20-alpine
WORKDIR /app

# Install pnpm
RUN npm install -g pnpm

# Copy only package files for install step
COPY ../../../../pnpm-workspace.yaml ../../../../pnpm-lock.yaml ./
COPY ../../../../packages ./packages
COPY ../../../../apps/api ./apps/api

WORKDIR /app/apps/api
RUN pnpm install --filter @clara/api...

# Expose dev port
EXPOSE 3000

# Enable hot reload and source mounting
CMD ["pnpm", "run", "dev"]
