{
	"name": "@clara/api",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "concurrently -k -n schemas,api -c yellow,cyan \"pnpm -w -F @clara/schemas build --watch\" \"ts-node-dev --respawn --transpile-only --ignore-watch node_modules --ignore-watch dist --ignore-watch tests --watch src src/index.ts\"",
		"start": "node dist/index.js",
		"build": "tsc -p tsconfig.json",
		"lint": "biome check",
		"format": "biome format \"**/*.{ts,tsx,js,json,md}\"",
		"test": "vitest",
		"test:ci": "pnpm -w -F @clara/schemas build && vitest run --reporter verbose"
	},
	"dependencies": {
		"@clara/schemas": "workspace:*",
		"@fastify/cors": "^11.2.0",
		"@fastify/static": "^9.0.0",
		"@fastify/swagger": "^9.6.1",
		"@fastify/swagger-ui": "^5.2.5",
		"fastify": "^5.7.2",
		"fastify-plugin": "^5.1.0",
		"swagger-ui-dist": "^5.31.0",
		"zod-to-json-schema": "^3.25.1",
		"uuid": "^9.0.0"
	},
	"devDependencies": {
		"concurrently": "^9.2.1",
		"ts-node-dev": "^2.0.0"
	}
}