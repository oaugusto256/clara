{
	"name": "@clara/api",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "pnpm -w -F @clara/schemas build --watch & ts-node-dev --respawn --transpile-only --ignore-watch node_modules --watch src src/index.ts",
		"start": "node dist/index.js",
		"build": "tsc -p tsconfig.json",
		"lint": "biome check",
		"format": "biome format \"**/*.{ts,tsx,js,json,md}\"",
		"test": "vitest",
		"test:ci": "pnpm -w -F @clara/schemas build && vitest run --reporter verbose"
	},
	"dependencies": {
		"@clara/schemas": "workspace:*",
		"fastify": "^4.24.0",
		"uuid": "^9.0.0"
	},
	"devDependencies": {
		"@types/uuid": "^11.0.0",
		"ts-node-dev": "^2.0.0"
	}
}
